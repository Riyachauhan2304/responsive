{
  "manifest_version": 3,
  "name": "MindGuard - Focus Firewall",
  "version": "2.0.0",

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js"
  },

  "action": {
    "default_popup": "popup.html"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],

  "web_accessible_resources": [
    {
      "resources": ["quiz.html", "quiz.js"],
      "matches": ["<all_urls>"]
    }
  ]
}